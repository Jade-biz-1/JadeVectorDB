# EnterpriseRAG Configuration

# ==================== Operation Mode ====================
# mock: Demo mode with simulated responses (no dependencies)
# production: Full RAG with JadeVectorDB + Ollama
MODE=mock

# ==================== Application ====================
APP_NAME=EnterpriseRAG
APP_VERSION=1.0.0
DEBUG=false

# ==================== API Server ====================
API_HOST=0.0.0.0
API_PORT=8000

# ==================== Frontend URL (for CORS) ====================
FRONTEND_URL=http://localhost:5173

# ==================== JadeVectorDB (Production Mode) ====================
JADEVECTORDB_URL=http://localhost:8080
JADEVECTORDB_API_KEY=
JADEVECTORDB_DATABASE_ID=maintenance_docs

# ==================== Ollama (Production Mode) ====================
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2:3b

# ==================== RAG Parameters ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.65

# ==================== Embeddings ====================
EMBEDDING_DIMENSION=384

# ==================== LLM Parameters ====================
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ==================== Document Upload ====================
MAX_UPLOAD_SIZE_MB=50
# Allowed extensions (comma-separated)
# ALLOWED_EXTENSIONS=[".pdf", ".docx"]

# ==================== Processing ====================
BATCH_SIZE=100
MAX_CONCURRENT_UPLOADS=3

# ==================== Timeouts (seconds) ====================
EMBEDDING_TIMEOUT=30
LLM_TIMEOUT=60
SEARCH_TIMEOUT=10
