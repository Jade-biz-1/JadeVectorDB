# ── EnterpriseRAG Docker environment ──────────────────────────
# Copy this to the repo root as .env before running docker compose:
#   cp EnterpriseRAG/.env.docker .env
#   docker compose up --build

# ── Operation mode ────────────────────────────────────────────
# mock       = simulated responses, no JadeVectorDB/Ollama needed
# production = full RAG pipeline (requires both services healthy)
MODE=production
DEBUG=false

# ── Ports (host-side) ─────────────────────────────────────────
JADEVECTORDB_PORT=8080
OLLAMA_PORT=11434
RAG_BACKEND_PORT=8000
RAG_FRONTEND_PORT=3002   # open http://localhost:3002 in your browser

# ── JadeVectorDB ──────────────────────────────────────────────
JADEVECTORDB_ENV=production
JADEVECTORDB_LOG_LEVEL=info
JADEVECTORDB_DATABASE_ID=rag_documents
# Vector dimension must match your embedding model:
#   nomic-embed-text → 768   |   E5-small → 384
EMBEDDING_DIMENSION=1024
# Admin credentials used by bootstrap.sh to log in to JadeVectorDB and
# generate a service API key.  In development mode the backend seeds
# admin/admin123 by default; change for production deployments.
JADEVECTORDB_ADMIN_USERNAME=admin
JADEVECTORDB_ADMIN_PASSWORD=admin123
# Leave empty to disable auth on JadeVectorDB API calls,
# or paste an API key created via POST /v1/api-keys
JADEVECTORDB_API_KEY=

# ── Ollama models ─────────────────────────────────────────────
# These are pulled automatically on first start (may take a few minutes)
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# ── RAG parameters ────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
MAX_UPLOAD_SIZE_MB=50
EMBEDDING_TIMEOUT=30
LLM_TIMEOUT=600
SEARCH_TIMEOUT=10

# ── EnterpriseRAG API auth ────────────────────────────────────
# Set a secret to protect /api/query, /api/stats, /api/analytics,
# and all /api/admin/* endpoints.  Leave empty to disable auth (dev only).
RAG_API_KEY=change-me-in-production

# ── JWT & bootstrap admin ─────────────────────────────────────
# Change JWT_SECRET_KEY to a long random string in production.
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin@1234
